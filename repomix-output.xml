                  onClick={() => {
                    if (!draft.strings) { setDraft(d => ({ ...d, strings: [i] })); return; }
                    const next = sel ? draft.strings.filter(x => x !== i) : [...draft.strings, i].sort((a, b) => a - b);
                    setDraft(d => ({ ...d, strings: next.length ? next : null }));
