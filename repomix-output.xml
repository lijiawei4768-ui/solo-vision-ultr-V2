                    }}>
                      {isZh ? mod.titleZh : mod.title}
                    </div>
                    <div style={{
                      fontSize: 11,
                      color: T.textTertiary,
                      marginTop: 2,
                      fontFamily: FONT_TEXT,
                    }}>
                      {isZh ? mod.descZh : mod.desc}
                    </div>
                  </div>

                  {/* Preset chips */}
