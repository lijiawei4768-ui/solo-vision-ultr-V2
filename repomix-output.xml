    {
      label: isZh ? "弱项音程" : "Weak Spots",
      value: `${(progress.weakIntervals || []).length}`,
      iconId: "weak",
    },
  ];

  return (
    <motion.div
      initial={{ opacity: 0, y: 10 }}
      animate={{ opacity: 1, y: 0 }}
