            ))}
          </div>
        </div>

        {/* Fret range */}
        <div style={{ marginBottom: 20 }}>
          <div style={{ fontSize: 10, color: T.textTertiary, letterSpacing: 1, textTransform: "uppercase", marginBottom: 4 }}>
            Fret Range
          </div>
          <FretRangeSlider
            value={{ start: draft.fretRange.min, end: draft.fretRange.max }}
