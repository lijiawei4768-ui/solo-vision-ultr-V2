}

// ─────────────────────────────────────────────────────────────
// QUICK STATS
// ─────────────────────────────────────────────────────────────
function QuickStats({ progress, isZh, T, isDark }) {
  const stats = [
    {
      label: isZh ? "连续天数" : "Streak",
      value: `${progress.streakDays || 0}${isZh ? "天" : "d"}`,
