          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {SPACE_PRESETS.map(p => (
              <button key={p.id}
                onClick={() => setDraft(d => ({ ...d, fretRange: p.fretRange, strings: p.strings, preset: p.id }))}
                style={{
                  padding: "10px 14px", borderRadius: 12, fontSize: 12,
