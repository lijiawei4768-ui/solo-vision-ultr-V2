              width: "100%", padding: "12px", borderRadius: 14, fontSize: 13, marginTop: 10,
              background: "transparent",
              border: `0.5px solid ${T.border ?? "rgba(255,255,255,0.1)"}`,
              color: "rgba(255,255,255,0.35)", cursor: "pointer", fontFamily: FONT_TEXT,
            }}>
            Disable Flow Mode
          </button>
        )}
      </div>
    </L2PushScreen>
  );
}

