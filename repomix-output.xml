            fontSize: 18,
            fontWeight: 700,
            color: T.textPrimary,
            fontFamily: FONT_DISPLAY,
            lineHeight: 1,
          }}>
            {s.value}
          </div>
          <div style={{
            fontSize: 10,
            color: T.textTertiary,
            marginTop: 3,
            fontFamily: FONT_TEXT,
          }}>
            {s.label}
          </div>
        </div>
      ))}
    </motion.div>
  );
}
