      </div>

      {/* Titles — bilingual */}
      <div style={{ textAlign: 'center', marginBottom: 20 }}>
        {/* English title */}
        <div style={{
          fontSize: 22, fontWeight: 800, letterSpacing: -0.6,
          color: T.textPrimary, fontFamily: FONT_DISPLAY, lineHeight: 1.2,
