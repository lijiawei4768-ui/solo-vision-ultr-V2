  const green = T.positive ?? "#22a672";

  const simNext = () => {
    if (verified < 5) {
      setVerified(v => v + 1);
      if (verified === 4) setTimeout(onDone, 600);
    }
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", justifyContent: "center", gap: 10, flex: 1 }}>
      {/* Top fraction + progress */}
      <motion.div
        initial={{ opacity: 0 }}
