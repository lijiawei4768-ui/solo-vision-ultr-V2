            </HeaderButton>
            <HeaderButton onClick={() => onOpen("system-hub")}>
              <Settings2 className="h-4 w-4" />
            </HeaderButton>
          </div>
        </header>

        <motion.div
          animate={pageMotion}
          transition={
            shot.id === "preview"
              ? { duration: 8, ease: [0.22, 1, 0.36, 1], times: [0, 0.18, 0.38, 0.58, 0.82, 1] }
              : { duration: 0.58, ease: [0.22, 1, 0.36, 1] }
          }
          style={{
            minHeight: 2140,
            transformOrigin: "50% 0%",
          }}>
          <HomeView
            settings={{ themeId: "petal-breeze", colorMode: "light" }}
            onTabChange={(trainerId) => onOpen(trainerId === "interval" ? "intervals-handoff" : "system-hub")}
            historyData={HOME_HISTORY}
            progress={HOME_PROGRESS}
            onRecalibrate={() => onOpen("feed-detail")}
          />
        </motion.div>
      </div>

      <EmbeddedTabBar />
