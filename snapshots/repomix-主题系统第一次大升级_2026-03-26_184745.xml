  return (
    <motion.nav
      animate={{
        y:              hidden ? "110%" : "0%",
        pointerEvents:  hidden ? "none" : "auto",
      }}
      transition={{
        type: "spring",
        stiffness: 380,
        damping: 36,
        mass: 0.9,
      }}
      style={{
        position: "fixed",
        bottom: 0,
        left: 0,
        right: 0,
        zIndex: 40,
        padding: "0 16px env(safe-area-inset-bottom, 16px)",
