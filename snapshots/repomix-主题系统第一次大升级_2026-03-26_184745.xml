                position: "absolute", left: `${(fret / 12) * 100}%`,
                top: 0, bottom: 0, width: "1px", background: "rgba(255,255,255,0.2)",
              }} />
            ))}
            {/* 把位标记 */}
            {[3, 5, 7, 9].map(fret => (
              <div key={`dot-${fret}`} style={{
