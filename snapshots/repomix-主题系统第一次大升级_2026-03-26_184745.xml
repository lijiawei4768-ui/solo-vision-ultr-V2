import { useEffect, useState } from "react";
import { AnimatePresence, motion } from "motion/react";
import { ArrowLeft, ArrowRight } from "lucide-react";

import { PresentationChrome } from "@/components/presentation/PresentationChrome";
import { StageBackdrop } from "@/components/presentation/StageBackdrop";
import { useThemeBridge } from "@/components/presentation/proof/ThemeBridge";
import { ProductSurfaceRenderer } from "@/components/presentation/ProductSurfaces";
import { Button } from "@/components/ui/button";
import { productScenes } from "@/data/product-scenes";

const PROOF_PAGE_SCENES = new Set(["brand-opening", "home", "intervals"]);

function useStageState(sceneList) {
  const [sceneIndex, setSceneIndex] = useState(0);
  const [stepIndex, setStepIndex] = useState(0);
  const [direction, setDirection] = useState(1);

  const scene = sceneList[sceneIndex];
  const maxStep = scene.steps.length - 1;

  const next = () => {
    setDirection(1);
    if (stepIndex < maxStep) {
      setStepIndex((value) => value + 1);
      return;
    }
    if (sceneIndex < sceneList.length - 1) {
      setSceneIndex((value) => value + 1);
      setStepIndex(0);
    }
  };

  const prev = () => {
    setDirection(-1);
    if (stepIndex > 0) {
      setStepIndex((value) => value - 1);
      return;
    }
    if (sceneIndex > 0) {
      const previousIndex = sceneIndex - 1;
      setSceneIndex(previousIndex);
      setStepIndex(sceneList[previousIndex].steps.length - 1);
    }
  };

  return { scene, sceneIndex, stepIndex, direction, next, prev };
}

function ProgressDots({ sceneIndex, total, stepIndex, stepTotal }) {
  return (
    <div className="flex items-center gap-3 rounded-full border border-[rgba(255,255,255,0.06)] bg-[rgba(8,10,15,0.42)] px-3 py-2 backdrop-blur-xl">
      <div className="flex gap-1.5">
        {Array.from({ length: total }).map((_, index) => (
          <div
            key={index}
            className={`h-1.5 rounded-full transition-all ${
              index === sceneIndex
                ? "w-8 bg-[rgba(230,216,187,0.86)]"
                : "w-2 bg-[rgba(255,255,255,0.14)]"
            }`}
          />
        ))}
      </div>
      <div className="text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.54)]">
        Step {stepIndex + 1}/{stepTotal}
      </div>
    </div>
  );
}

function ProofShotBar({ stepIndex, stepTotal }) {
  return (
    <div className="pointer-events-none w-[min(380px,54vw)]">
      <div className="flex items-center gap-2 rounded-full border border-[rgba(125,142,186,0.14)] bg-[rgba(255,255,255,0.58)] px-3 py-2 shadow-[0_8px_24px_rgba(92,108,148,0.06)] backdrop-blur-[20px]">
        <div className="flex flex-1 gap-1.5">
          {Array.from({ length: stepTotal }).map((_, index) => (
            <div
              key={index}
              className={`h-1.5 rounded-full transition-all ${
                index === stepIndex ? "flex-[1.8] bg-[rgba(90,90,214,0.72)]" : "flex-1 bg-[rgba(111,128,214,0.12)]"
              }`}
            />
          ))}
        </div>
        <div className="text-[10px] uppercase tracking-[0.22em] text-[rgba(82,82,122,0.7)]">
          {stepIndex + 1}/{stepTotal}
        </div>
      </div>
    </div>
  );
}

export default function App() {
  const { scene, sceneIndex, stepIndex, direction, next, prev } = useStageState(productScenes);
  const isProofPage = PROOF_PAGE_SCENES.has(scene.id);
  const theme = useThemeBridge();

  const handleStageClick = (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      next();
      return;
    }

    const interactive = target.closest(
      "button, a, input, textarea, select, [role='tab'], [data-slot='tabs-trigger']",
    );

    if (interactive) {
      return;
    }

    next();
  };

  useEffect(() => {
    const onKeyDown = (event) => {
      if (event.code === "Space" || event.key === "ArrowRight" || event.key === "Enter") {
        event.preventDefault();
        next();
      }
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        prev();
      }
    };

    window.addEventListener("keydown", onKeyDown);
    return () => window.removeEventListener("keydown", onKeyDown);
  }, [next, prev]);

  return (
    <div
      className={`relative h-screen overflow-hidden ${
        isProofPage
          ? ""
          : "bg-[#05070b] text-[rgba(247,242,233,0.95)]"
      }`}
      style={isProofPage ? { background: `linear-gradient(180deg, ${theme.surface0}, #eef2f8)` } : undefined}
      onClick={handleStageClick}
      role="presentation">
      <StageBackdrop sceneIndex={sceneIndex} sceneId={scene.id} />

      <div
        className={`relative z-10 flex h-full flex-col ${
          isProofPage ? "px-4 pb-4 pt-4 md:px-6 md:pb-5 md:pt-5" : "px-5 pb-5 pt-5 md:px-8 lg:px-10"
        }`}>
        {!isProofPage ? (
          <PresentationChrome
            sceneIndex={sceneIndex}
            totalScenes={productScenes.length}
            title={scene.title}
            subtitle={scene.subtitle}
          />
        ) : null}

        {!isProofPage ? (
          <div className="mb-3 flex justify-center">
            <ProgressDots
              sceneIndex={sceneIndex}
              total={productScenes.length}
              stepIndex={stepIndex}
              stepTotal={scene.steps.length}
            />
          </div>
        ) : null}

        {isProofPage ? (
          <div className="relative z-20 mb-3 flex items-center justify-between gap-3 px-1 md:mb-4 md:px-2">
            <div className="w-[158px] shrink-0" />
            <div className="flex flex-1 justify-center">
              <ProofShotBar stepIndex={stepIndex} stepTotal={scene.steps.length} />
            </div>
            <div className="pointer-events-auto flex shrink-0 items-center gap-2 rounded-full border border-[rgba(125,142,186,0.16)] bg-[rgba(255,255,255,0.62)] px-2 py-2 shadow-[0_12px_28px_rgba(84,98,136,0.08)] backdrop-blur-[20px]">
              <Button
                variant="ghost"
                size="sm"
                className="rounded-full px-3 text-[rgba(23,29,49,0.82)]"
                onClick={(event) => {
                  event.stopPropagation();
                  prev();
                }}>
                <ArrowLeft className="h-4 w-4" />
                上一幕
              </Button>
              <Button
                variant="ghost"
                size="sm"
                className="rounded-full px-3 text-[rgba(23,29,49,0.82)]"
                onClick={(event) => {
                  event.stopPropagation();
                  next();
                }}>
                下一幕
                <ArrowRight className="h-4 w-4" />
              </Button>
            </div>
          </div>
        ) : null}

        <div className="relative min-h-0 flex-1">
          <AnimatePresence mode="wait" custom={direction}>
            <motion.div
              key={scene.id}
              custom={direction}
              initial={isProofPage ? { opacity: 0, y: 10 } : { opacity: 0, y: 22, filter: "blur(12px)" }}
              animate={isProofPage ? { opacity: 1, y: 0 } : { opacity: 1, y: 0, filter: "blur(0px)" }}
              exit={isProofPage ? { opacity: 0, y: -8 } : { opacity: 0, y: -18, filter: "blur(10px)" }}
              transition={{ duration: isProofPage ? 0.34 : 0.52, ease: [0.22, 1, 0.36, 1] }}
              className="h-full">
              <ProductSurfaceRenderer scene={scene} stepIndex={stepIndex} />
            </motion.div>
          </AnimatePresence>
        </div>

        {!isProofPage ? (
          <div className="pointer-events-none absolute inset-x-0 bottom-5 flex justify-center">
            <div className="pointer-events-auto flex items-center gap-2 rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(7,10,14,0.68)] px-2 py-2 backdrop-blur-xl">
              <Button
                variant="ghost"
                size="sm"
                className="rounded-full px-3 text-[rgba(235,239,244,0.84)]"
                onClick={(event) => {
                  event.stopPropagation();
                  prev();
                }}>
                <ArrowLeft className="h-4 w-4" />
                上一幕
              </Button>
              <Button
                variant="ghost"
                size="sm"
                className="rounded-full px-3 text-[rgba(235,239,244,0.84)]"
                onClick={(event) => {
                  event.stopPropagation();
                  next();
                }}>
                下一幕
                <ArrowRight className="h-4 w-4" />
              </Button>
            </div>
          </div>
        ) : null}
      </div>
    </div>
  );
}
