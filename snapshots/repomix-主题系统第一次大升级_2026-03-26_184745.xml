<file path="standalone-demo/launch/src/components/presentation/proof/ThemeBridge.jsx">
import { createContext, useContext, useMemo, useState } from "react";

import {
  ACCENT_SCHEMES,
  BG_SCHEMES,
  SURFACE_SCHEMES,
  getSurfaceBg,
  getSurfaceFilter,
} from "../../../../../../src/theme.js";

const ThemeBridgeContext = createContext(null);

function hexToRgba(hex, alpha) {
  if (!hex) return `rgba(90,90,214,${alpha})`;
  const h = hex.replace("#", "");
  const r = Number.parseInt(h.slice(0, 2), 16);
  const g = Number.parseInt(h.slice(2, 4), 16);
  const b = Number.parseInt(h.slice(4, 6), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function buildBridgeTheme({ bgScheme = "frost-light", accentId = "indigo", surfaceId = "glass-mid" } = {}) {
  const bg = BG_SCHEMES[bgScheme] ?? BG_SCHEMES["frost-light"];
  const accent = ACCENT_SCHEMES[accentId] ?? ACCENT_SCHEMES.indigo;
  const surface = SURFACE_SCHEMES[surfaceId] ?? SURFACE_SCHEMES["glass-mid"];
  const isDark = Boolean(bg.dark);

  return {
    bgScheme,
    accentSchemeId: accent.id,
    surfaceSchemeId: surface.id,
    bg: {
      base: bg.base,
      blobA: bg.blobA,
      blobB: bg.blobB,
      blobC: bg.blobC,
    },
    glass: {
      surface1: getSurfaceBg(surface, bg.glassBase, isDark),
      border: bg.glassBorder,
      blur: getSurfaceFilter(surface),
      shadow: isDark ? surface.shadowDark : surface.shadowLight,
    },
    accent: accent.accent,
    accentAlt: accent.accentAlt,
    accentSub: hexToRgba(accent.accent, isDark ? 0.16 : 0.1),
    accentBorder: hexToRgba(accent.accent, isDark ? 0.3 : 0.22),
    positive: accent.positive,
    warning: accent.warning,
    negative: accent.negative,
    noteRoot: accent.noteRoot,
    noteTarget: accent.noteTarget,
    noteScale: accent.noteScale,
    textPrimary: isDark ? "rgba(255,255,255,0.95)" : "rgba(19,19,42,0.92)",
    textSecondary: isDark ? "rgba(230,233,242,0.72)" : "rgba(82,82,122,0.88)",
    textTertiary: isDark ? "rgba(194,203,216,0.54)" : "rgba(152,152,184,0.8)",
    surface0: bg.base,
    surface1: getSurfaceBg(surface, bg.glassBase, isDark),
    surface2: isDark ? "rgba(18,20,30,0.84)" : "rgba(255,255,255,0.9)",
    surface3: isDark ? "rgba(255,255,255,0.08)" : "rgba(18,24,36,0.06)",
    border: hexToRgba(accent.accent, isDark ? 0.18 : 0.12),
    borderHi: hexToRgba(accent.accent, isDark ? 0.28 : 0.2),
    isDark,
  };
}

const DEFAULT_THEME = buildBridgeTheme();

export function ThemeBridgeProvider({ children }) {
  const [themeConfig] = useState({
    bgScheme: "frost-light",
    accentId: "indigo",
    surfaceId: "glass-mid",
  });
  const value = useMemo(() => buildBridgeTheme(themeConfig), [themeConfig]);
  return <ThemeBridgeContext.Provider value={value}>{children}</ThemeBridgeContext.Provider>;
}

export function useThemeBridge() {
  return useContext(ThemeBridgeContext) || DEFAULT_THEME;
}
