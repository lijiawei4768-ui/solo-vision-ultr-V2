              style={{
                padding: "5px 11px",
                borderRadius: 10,
                fontSize: 12,
                fontWeight: 600,
                fontFamily: FONT_TEXT,
                cursor: "pointer",
                border: `0.5px solid ${audioEnabled ? "rgba(52,199,89,0.5)" : DT.border}`,
                background: audioEnabled ? "rgba(52,199,89,0.15)" : DT.surface2,
                color: audioEnabled ? DT.positive : DT.textTertiary,
