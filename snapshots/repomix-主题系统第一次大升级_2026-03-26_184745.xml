        background: T.accentSub ?? "rgba(232,162,60,0.1)",
        border: `0.5px solid ${T.accentBorder ?? "rgba(232,162,60,0.35)"}`,
        color: T.accent ?? "#E8A23C", cursor: "pointer", fontFamily: FONT_TEXT,
      }}>Apply Zone</button>
    </div>
