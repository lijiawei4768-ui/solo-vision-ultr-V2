import { motion } from "motion/react";

function LensPanel({ children, side = "center", visible = true }) {
  const variants = {
    center: "mx-auto w-full max-w-[980px]",
    left: "absolute left-[2%] top-[8%] w-[28%] origin-left",
    right: "absolute right-[2%] top-[8%] w-[28%] origin-right",
  };

  const motionProps =
    side === "center"
      ? {
          initial: { opacity: 0, y: 32, scale: 0.94, filter: "blur(18px)" },
          animate: { opacity: 1, y: 0, scale: 1, filter: "blur(0px)" },
          transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] },
        }
      : {
          initial: {
            opacity: 0,
            x: side === "left" ? -44 : 44,
            scale: 0.9,
            rotateY: side === "left" ? 12 : -12,
            filter: "blur(10px)",
          },
          animate: {
            opacity: visible ? 0.52 : 0,
            x: 0,
            scale: visible ? 0.92 : 0.88,
            rotateY: side === "left" ? 10 : -10,
            filter: visible ? "blur(0px)" : "blur(10px)",
          },
          transition: { duration: 0.8, ease: [0.22, 1, 0.36, 1] },
        };

  return (
    <motion.div style={{ transformStyle: "preserve-3d" }} className={variants[side]} {...motionProps}>
      {children}
    </motion.div>
  );
}

export function LensStage({ center, left, right, showSides = false }) {
  return (
    <div className="relative h-full min-h-0 [perspective:2200px]">
      <div className="pointer-events-none absolute inset-0">
