<file path="standalone-demo/launch/src/components/presentation/surfaces/batch-b/intervals/IntervalsModuleCard.jsx">
import { motion } from "motion/react";

import { useThemeBridge } from "@/components/presentation/proof/ThemeBridge";

export function IntervalsModuleCard({ title, label, mode, action, children }) {
  const theme = useThemeBridge();
  const animate =
    mode === "focal"
      ? {
          opacity: 1,
          scale: 1.016,
          filter: "blur(0px)",
          borderColor: theme.accentBorder,
          boxShadow: "0 18px 40px rgba(90,90,214,0.12)",
        }
      : mode === "dim"
        ? {
            opacity: 0.6,
            scale: 0.992,
            filter: "blur(0.8px)",
            borderColor: "rgba(94,112,156,0.08)",
            boxShadow: "0 10px 24px rgba(72,90,135,0.04)",
          }
        : {
            opacity: 1,
            scale: 1,
            filter: "blur(0px)",
            borderColor: "rgba(94,112,156,0.12)",
            boxShadow: "0 12px 30px rgba(72,90,135,0.07)",
          };

  return (
    <motion.section
      animate={animate}
      transition={{ duration: 0.45, ease: [0.22, 1, 0.36, 1] }}
      className="rounded-[26px] border p-4"
      style={{ background: theme.surface1 }}>
      <div className="mb-3 flex items-start justify-between gap-3">
        <div>
          <div className="text-[10px] uppercase tracking-[0.24em]" style={{ color: theme.textTertiary }}>{label}</div>
          <div className="mt-1 text-[1rem] font-semibold tracking-[-0.03em]" style={{ color: theme.textPrimary }}>{title}</div>
        </div>
        {action}
      </div>
      {children}
    </motion.section>
  );
}
</file>

