<file path="standalone-demo/launch/src/components/presentation/chrome/stage-camera.js">
const STAGE_VIEWPORT = {
  width: 980,
  height: 760,
};

function mapScale(input, baseScale) {
  if (Array.isArray(input)) return input.map((value) => value * baseScale);
  return (input ?? 1) * baseScale;
}

function getSubjectPlacement(shot) {
  if (shot.subjectPlacement) return shot.subjectPlacement;
  if (shot.placement === "left") return "right";
  if (shot.placement === "right") return "left";
  return "center";
}

function getTargetAnchor(placement) {
  if (placement === "left") return { x: 0.34, y: 0.48 };
  if (placement === "right") return { x: 0.66, y: 0.48 };
  return { x: 0.5, y: 0.47 };
}

export function buildStageCamera({
  shot,
  focusRect,
  baseScale,
  previewMotion,
}) {
  if (shot.id === "preview") {
    return {
      x: previewMotion.x ?? 0,
      y: previewMotion.y,
      scale: mapScale(previewMotion.scale, baseScale),
    };
  }

  if (!focusRect) {
    return {
      x: shot.panX ?? 0,
      y: shot.scrollY ?? shot.panY ?? 0,
      scale: mapScale(shot.zoom, baseScale),
    };
  }

  const placement = getSubjectPlacement(shot);
  const anchor = getTargetAnchor(placement);
  const focusCenterX = focusRect.x + focusRect.w / 2;
  const focusCenterY = focusRect.y + focusRect.h / 2;
  const scaleBoost = shot.focusScale ?? (placement === "center" ? 1.18 : 1.12);
  const scale = baseScale * scaleBoost;

  return {
    x: (anchor.x - focusCenterX) * STAGE_VIEWPORT.width + (shot.panX ?? 0),
    y: (anchor.y - focusCenterY) * STAGE_VIEWPORT.height + (shot.panY ?? shot.scrollY ?? 0),
    scale,
  };
}
</file>

