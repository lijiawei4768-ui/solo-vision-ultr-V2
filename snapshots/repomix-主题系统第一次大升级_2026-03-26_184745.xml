            <Panel title="L1 Notes Controls" label="Target Type / Display / Space / Challenge">
              <div className="grid gap-3 md:grid-cols-2">
                <Metric label="Target Type" value={modes[stepIndex]} tone="warm" />
                <Metric label="Display" value={stepIndex === 0 ? "Show on correct" : "Show context"} tone="cool" />
                <Metric label="Space" value={stepIndex === 1 ? "Strings G/B · Pos 5-9" : "Pos 1-5"} />
