    "给音名，在区域内找出来。是其他模式的地基。",
    "给 root + degree，在区域内定位。这一层把 Notes 接到 Intervals / Scales。",
    "给和弦名，找 1/3/5/7/guide tones / tension。这一层把 Notes 接到 Chords。",
    "限时、连击、节奏触发、错误惩罚。把“认识”变成“反应”。",
  ];

  return (
    <StageFrame scene={scene} step={step}>
      <div className="grid h-full gap-4 xl:grid-cols-[0.3fr_0.7fr]">
