<file path="standalone-demo/launch/src/components/presentation/surfaces/batch-b/ScalesSurface.jsx">
import { GitBranch, Layers2, Waypoints } from "lucide-react";

import { StageFrame } from "@/components/presentation/chrome/StageFrame";
import { Chip, HeaderRail, Metric, Panel, SidebarSection } from "@/components/presentation/chrome/SurfacePrimitives";

export function ScalesSurface({ scene, step, stepIndex }) {
  const systems = ["CAGED", "3NPS", "Horizontal", "Hybrid"];
  const modes = ["Pattern", "System", "Sequence", "Connection", "Target Tone"];

  return (
    <StageFrame scene={scene} step={step}>
      <div className="grid h-full gap-4 xl:grid-cols-[0.3fr_0.7fr]">
        <div className="grid gap-4">
          <SidebarSection title="Modes" items={modes} activeIndex={Math.min(stepIndex + 1, 4)} />
          <Panel title="System 在主位" label="Hard Rule">
            <div className="space-y-3 text-sm leading-7 text-[rgba(205,214,225,0.72)]">
              <div>Scales 练系统，不是练一堆 box。System 必须在主位，不能退回 L2。</div>
              <div>这是唯一一个 Space + Flow 都真正进入训练引擎主层的 trainer。</div>
            </div>
          </Panel>
        </div>

        <div className="grid gap-4">
          <HeaderRail
            left={
              <>
                <Waypoints className="h-4 w-4" />
                <span>Scales / Scale Systems</span>
              </>
            }
            right={
              <>
                {systems.map((item, index) => (
                  <Chip key={item} active={index === stepIndex}>
                    {item}
