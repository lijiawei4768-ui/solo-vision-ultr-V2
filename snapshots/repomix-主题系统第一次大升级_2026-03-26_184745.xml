import { AnimatePresence, motion } from "motion/react";
import { useEffect, useMemo, useState } from "react";

import { ShowcaseStage } from "@/components/presentation/chrome/ShowcaseStage";
import { StageFrame } from "@/components/presentation/chrome/StageFrame";
import { DirectorLayer } from "@/components/presentation/proof/DirectorLayer";
import { DestinationSheet } from "@/components/presentation/proof/DestinationSheet";
import {
  INTERVAL_DESTINATIONS,
  INTERVAL_PREVIEW_MOTION,
  getIntervalShot,
} from "@/components/presentation/surfaces/batch-b/intervals/intervals-filmstrip-data";
import { IntervalsTrainerMirror } from "@/components/presentation/surfaces/batch-b/intervals/mirror/IntervalsTrainerMirror";
import { SPRING_SOFT } from "@/components/presentation/theme/animations";
import { buildStageCamera } from "@/components/presentation/chrome/stage-camera";

const ARTBOARD_WIDTH = 620;
const ARTBOARD_HEIGHT = 1180;
const BASE_ARTBOARD_SCALE = 0.64;

const INTERVAL_FOCUS_RECTS = {
  prompt: { x: 0.12, y: 0.14, w: 0.76, h: 0.16 },
  modes: { x: 0.12, y: 0.08, w: 0.76, h: 0.18 },
  fretboard: { x: 0.07, y: 0.31, w: 0.86, h: 0.31 },
  runtime: { x: 0.09, y: 0.64, w: 0.82, h: 0.16 },
  controls: { x: 0.09, y: 0.73, w: 0.82, h: 0.18 },
  depth: { x: 0.09, y: 0.71, w: 0.82, h: 0.2 },
};

export function IntervalsSurface({ scene, stepIndex }) {
  const shot = getIntervalShot(stepIndex);
  const [activeDestination, setActiveDestination] = useState(null);
  useEffect(() => {
    setActiveDestination(shot.autoDestination ?? null);
  }, [shot.id, shot.autoDestination]);

  const destination = activeDestination ? INTERVAL_DESTINATIONS[activeDestination] : null;
  const focusRect = shot.focal ? INTERVAL_FOCUS_RECTS[shot.focal] ?? null : null;
  const pageMotion = useMemo(
    () =>
      buildStageCamera({
        shot,
        focusRect,
        baseScale: BASE_ARTBOARD_SCALE,
        previewMotion: INTERVAL_PREVIEW_MOTION,
      }),
    [shot, focusRect],
  );

  return (
    <StageFrame scene={scene} step={scene.steps[Math.min(stepIndex, scene.steps.length - 1)]} minimal>
      <div className="relative flex h-full min-h-0 items-center justify-center overflow-hidden">
        <ShowcaseStage pageX={shot.pageX ?? 0}>
          <div className="flex h-full w-full items-center justify-center">
            <motion.div
              animate={{
                x: pageMotion.x ?? 0,
                y: pageMotion.y,
                scale: pageMotion.scale ?? BASE_ARTBOARD_SCALE,
              }}
              transition={shot.id === "preview" ? { duration: 8, ease: [0.22, 1, 0.36, 1], times: [0, 0.18, 0.38, 0.58, 0.82, 1] } : SPRING_SOFT}
              style={{
                transformOrigin: "50% 0%",
                width: ARTBOARD_WIDTH,
                height: ARTBOARD_HEIGHT,
                flexShrink: 0,
              }}>
              <IntervalsTrainerMirror shot={shot} />
            </motion.div>
          </div>

          <AnimatePresence>
            {destination ? (
              <DestinationSheet
                destination={destination}
                onClose={() => setActiveDestination(null)}
                onOpen={setActiveDestination}
                passive={Boolean(shot.autoDestination && activeDestination === shot.autoDestination)}
              />
            ) : null}
          </AnimatePresence>

          <AnimatePresence mode="wait">
            <DirectorLayer key={shot.id} prefix="Intervals Filmstrip" shot={shot} focusRect={focusRect} />
          </AnimatePresence>
        </ShowcaseStage>
      </div>
    </StageFrame>
  );
}
</file>

