}

function HomeSurfaceFrame({ shot, onOpen }) {
  return (
    <LangContext.Provider value={{ lang: "mixed", setLang: () => {} }}>
      <ThemeContext.Provider value={{ dark: false, toggle: () => {}, tokens: HOME_THEME }}>
        <HomeArtboard shot={shot} onOpen={onOpen} />
      </ThemeContext.Provider>
    </LangContext.Provider>
  );
}

export function HomeLaunchSurface({ scene, stepIndex }) {
  const shot = getHomeShot(stepIndex);
  const [activeDestination, setActiveDestination] = useState(null);

  useEffect(() => {
    setActiveDestination(shot.autoDestination ?? null);
  }, [shot.id, shot.autoDestination]);

  const destination = activeDestination ? HOME_DESTINATIONS[activeDestination] : null;
  const focusRect = shot.focal ? HOME_FOCUS_RECTS[shot.focal] ?? null : null;

  return (
    <StageFrame scene={scene} step={scene.steps[Math.min(stepIndex, scene.steps.length - 1)]} minimal>
      <div className="relative flex h-full min-h-0 items-center justify-center overflow-hidden">
        <ShowcaseStage pageX={shot.pageX ?? 0}>
          <div className="flex h-full w-full items-center justify-center">
            <div
              style={{
                width: ARTBOARD_WIDTH,
                height: ARTBOARD_HEIGHT,
                flexShrink: 0,
              }}>
              <HomeSurfaceFrame shot={shot} onOpen={setActiveDestination} />
            </div>
          </div>

          <AnimatePresence>
            {destination ? (
              <DestinationSheet
                destination={destination}
                onClose={() => setActiveDestination(null)}
                onOpen={setActiveDestination}
                passive={Boolean(shot.autoDestination && activeDestination === shot.autoDestination)}
              />
            ) : null}
          </AnimatePresence>

          <AnimatePresence mode="wait">
            <DirectorLayer key={shot.id} prefix="Home Filmstrip" shot={shot} focusRect={focusRect} />
          </AnimatePresence>
        </ShowcaseStage>
      </div>
    </StageFrame>
  );
}
