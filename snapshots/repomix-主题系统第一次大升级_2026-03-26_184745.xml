<file path="standalone-demo/launch/src/components/presentation/proof/FilmCaption.jsx">
import { motion } from "motion/react";

import { TextAnimate } from "@/components/ui/text-animate";
import { useThemeBridge } from "@/components/presentation/proof/ThemeBridge";

export function FilmCaption({ prefix, shot, focusRect = null }) {
  const theme = useThemeBridge();
  const placement = shot.placement === "bottom" ? "bottom-center" : shot.placement;
  const rectCenterY = focusRect ? focusRect.y + focusRect.h / 2 : 0.5;
  const rectBottom = focusRect ? focusRect.y + focusRect.h : 0.78;
  const position =
    placement === "left"
      ? { left: "28px", top: `${rectCenterY * 100}%`, transform: "translateY(-50%)", width: "min(308px, 25vw)" }
      : placement === "right"
        ? { right: "28px", top: `${rectCenterY * 100}%`, transform: "translateY(-50%)", width: "min(308px, 25vw)" }
        : focusRect
          ? { left: "50%", top: `min(calc(${rectBottom * 100}% + 18px), calc(100% - 136px))`, transform: "translateX(-50%)", width: "min(560px, 48vw)" }
          : { left: "50%", bottom: "16px", transform: "translateX(-50%)", width: "min(560px, 48vw)" };

  return (
    <motion.div
      key={`${prefix}-${shot.id}-caption`}
      initial={{
        opacity: 0,
        y: placement === "bottom-center" ? 16 : 0,
        x: placement === "left" ? -18 : placement === "right" ? 18 : 0,
      }}
      animate={
        placement === "bottom-center"
          ? { opacity: [0, 1, 1, 0], x: 0, y: [16, 0, 0, 8] }
          : { opacity: 1, x: 0, y: 0 }
      }
      exit={{ opacity: 0, y: 10 }}
      transition={
        placement === "bottom-center"
          ? { duration: 4.8, times: [0, 0.18, 0.72, 1], ease: [0.22, 1, 0.36, 1] }
          : { type: "spring", stiffness: 280, damping: 30 }
      }
      className="pointer-events-none absolute z-30"
      style={position}>
      <div
        className="rounded-[22px] px-4 py-3 backdrop-blur-[18px]"
        style={{
          border: `1px solid ${theme.border}`,
          background: "rgba(255,255,255,0.58)",
          boxShadow: "0 10px 30px rgba(84,98,136,0.08)",
        }}>
        <div className="mb-2 flex items-center gap-3">
          <div className="text-[10px] uppercase tracking-[0.28em]" style={{ color: theme.textTertiary }}>
            {prefix}
          </div>
          <div className="h-px flex-1" style={{ background: theme.border }} />
          <div className="text-[10px] uppercase tracking-[0.22em]" style={{ color: theme.textTertiary }}>
            {shot.label}
          </div>
        </div>
        <TextAnimate
          key={shot.id}
          as="p"
          by="character"
          animation="blurInUp"
          duration={1.08}
          className="text-[0.92rem] leading-7 md:text-[0.98rem] md:leading-8"
          style={{ color: theme.textSecondary }}>
          {shot.narration}
        </TextAnimate>
      </div>
    </motion.div>
  );
}
</file>

