                  transition={{ delay: (rowIndex * 6 + index) * 0.02, duration: 0.24 }}
                  className="h-16 rounded-[18px] border border-[rgba(255,255,255,0.08)]"
                  style={{
                    background: `linear-gradient(180deg, rgba(226,214,186,${Math.max(0.08, strength / 180)}), rgba(132,161,205,${Math.max(0.04, strength / 220)}))`,
                  }}
                />
              );
            })}
          </div>
        </div>
      ))}
    </div>
  );
}

function Live({ prompt, status, events }) {
  return (
    <div className="grid h-full gap-4 xl:grid-cols-[minmax(0,1.15fr)_220px]">
      <div className="rounded-[30px] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] p-5">
