            }
            right={
              <>
                {modes.map((item, index) => (
                  <Chip key={item} active={index === stepIndex}>
                    {item}
                  </Chip>
                ))}
              </>
            }
          />

          <div className="grid flex-1 gap-4 lg:grid-cols-[0.92fr_1.08fr]">
            <Panel title="NotesFocusCard" label="L0 Main Screen">
              <div className="space-y-4">
                <div className="text-[10px] uppercase tracking-[0.26em] text-[rgba(194,203,216,0.46)]">Target Type</div>
                <div className="text-[3.8rem] font-semibold leading-none tracking-[-0.08em] text-[rgba(250,246,238,0.98)]">
