// ── Re-export three-axis scheme data for convenience ──────────
export {
  BG_SCHEMES,
  DARK_BG_SCHEMES,
  LIGHT_BG_SCHEMES,
  RECOMMENDED_DARK_BG_SCHEMES,
  RECOMMENDED_LIGHT_BG_SCHEMES,
  DEFAULT_BG_DARK,
  DEFAULT_BG_LIGHT,
  ACCENT_SCHEMES,
  ACCENT_SCHEME_KEYS,
  DEFAULT_ACCENT_DARK,
  DEFAULT_ACCENT_LIGHT,
  SURFACE_SCHEMES,
  SURFACE_SCHEME_KEYS,
  DEFAULT_SURFACE,
  getSurfaceFilter,
  getSurfaceBg,
  PRESETS,
  PRESET_KEYS,
  DEFAULT_PRESET,
  CURATED_DARK_THEME_IDS,
  CURATED_LIGHT_THEME_IDS,
