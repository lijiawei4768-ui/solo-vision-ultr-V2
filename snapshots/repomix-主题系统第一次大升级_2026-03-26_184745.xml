export function filmstripPlacementClass(placement) {
  if (placement === "left") {
    return "left-4 top-1/2 w-[320px] -translate-y-1/2 md:left-6 md:w-[360px]";
  }
  if (placement === "right") {
    return "right-4 top-1/2 w-[320px] -translate-y-1/2 md:right-6 md:w-[360px]";
  }
  return "bottom-2 left-1/2 w-[min(88vw,900px)] -translate-x-1/2";
}
