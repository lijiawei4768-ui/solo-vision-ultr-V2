        <div className="mt-4 text-[1.45rem] tracking-[-0.04em] text-[rgba(248,244,236,0.96)]">{prompt}</div>
        <div className="mt-6 flex flex-col gap-3">
          {events.map((event) => (
            <div
              key={event}
              className="rounded-[22px] border border-[rgba(255,255,255,0.08)] bg-[rgba(10,14,20,0.52)] px-4 py-3 text-sm text-[rgba(223,229,236,0.82)]">
              {event}
            </div>
          ))}
        </div>
      </div>
      <div className="rounded-[30px] border border-[rgba(226,214,186,0.12)] bg-[rgba(226,214,186,0.04)] p-5">
        <div className="text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.44)]">Status</div>
        <div className="mt-4 text-[1.5rem] tracking-[-0.04em] text-[rgba(248,244,236,0.96)]">{status}</div>
        <Separator className="my-5 bg-[rgba(255,255,255,0.08)]" />
        <div className="space-y-2">
          <Pill>Prompt active</Pill>
          <Pill>Audio listening</Pill>
          <Pill>Feedback ready</Pill>
        </div>
      </div>
    </div>
  );
}

export function SceneVisual({ scene, step }) {
  const visual = step.visual ?? {};

  return (
    <VisualFrame eyebrow={scene.englishLabel} title={step.heading} detail={scene.categoryLabel}>
      {visual.type === "hero" ? <Hero {...visual} /> : null}
