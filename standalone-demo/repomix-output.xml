          <div className="absolute inset-x-8 top-7 h-[88px] rounded-[24px] border px-8 py-6" style={{ borderColor: theme.border, background: theme.surface1 }}>
            <div className="text-[10px] uppercase tracking-[0.24em]" style={{ color: theme.textTertiary }}>HomeView Upgraded</div>
