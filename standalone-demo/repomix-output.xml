import { StageFrame } from "@/components/presentation/chrome/StageFrame";
import { DestinationSheet } from "@/components/presentation/proof/DestinationSheet";
import { FilmCaption } from "@/components/presentation/proof/FilmCaption";
import { ThemeContext } from "@/components/presentation/surfaces/batch-a/home/contexts";
import { HOME_DESTINATIONS, HOME_PREVIEW_MOTION, getHomeShot } from "@/components/presentation/surfaces/batch-a/home/home-filmstrip-data";
import { LangContext } from "@/components/presentation/surfaces/batch-a/home/i18n";
import { FONT_DISPLAY, FONT_TEXT, getTokensForTheme } from "@/components/presentation/surfaces/batch-a/home/theme";
import { HomeView } from "@/components/presentation/surfaces/batch-a/home/mirror/HomeViewMirror";

const HOME_THEME = getTokensForTheme("petal-breeze");
const ARTBOARD_WIDTH = 560;
const ARTBOARD_HEIGHT = 1180;
const ARTBOARD_SCALE = 1.72;

const HOME_PROGRESS = {
  todayMinutes: 0,
  streakDays: 1,
  totalSessions: 1,
  weakIntervals: ["b3"],
  intervalHeatmap: {},
};

const HOME_HISTORY = {
  history: [],
  heatmap: {},
  accuracy: 0,
  byTab: [],
  lastTab: "home",
  streak: 1,
};

const TABS = [
  { id: "home", label: "Home", icon: "⌂" },
  { id: "note", label: "Notes", icon: "♩" },
  { id: "interval", label: "Intervals", icon: "◎" },
  { id: "changes", label: "Changes", icon: "♫" },
  { id: "scale", label: "Scales", icon: "≋" },
  { id: "persona", label: "Me", icon: "◉" },
];

function HeaderButton({ children, onClick }) {
  return (
    <motion.button
      whileTap={{ scale: 0.88 }}
      onClick={onClick}
      style={{
        width: 34,
        height: 34,
        borderRadius: 10,
        background: HOME_THEME.surface2,
        border: `0.5px solid ${HOME_THEME.border}`,
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        fontSize: 16,
        cursor: "pointer",
        color: HOME_THEME.textPrimary,
      }}>
      {children}
    </motion.button>
  );
}

function EmbeddedTabBar() {
  const navBg = "rgba(240,240,246,0.92)";

  return (
    <motion.nav
      style={{
        position: "absolute",
        bottom: 0,
        left: 0,
        right: 0,
        zIndex: 5,
        padding: "0 16px 16px",
        display: "flex",
        justifyContent: "center",
      }}>
      <div
        style={{
          width: "100%",
          maxWidth: ARTBOARD_WIDTH,
          background: navBg,
          backdropFilter: "blur(32px)",
          WebkitBackdropFilter: "blur(32px)",
          borderTop: `0.5px solid ${HOME_THEME.border}`,
          borderLeft: `0.5px solid ${HOME_THEME.border}`,
          borderRight: `0.5px solid ${HOME_THEME.border}`,
          borderBottom: `0.5px solid ${HOME_THEME.border}`,
          borderRadius: 28,
          boxShadow: "0 -4px 24px rgba(0,0,0,0.08)",
        }}>
        <div style={{ display: "flex", padding: 4 }}>
          {TABS.map((tab) => {
            const active = tab.id === "home";
            return (
              <motion.button
                key={tab.id}
                whileTap={{ scale: 0.9 }}
                style={{
                  flex: 1,
                  display: "flex",
                  flexDirection: "column",
                  alignItems: "center",
                  padding: "9px 2px",
                  borderRadius: 22,
                  position: "relative",
                  border: "none",
                  cursor: "pointer",
                  background: active ? "rgba(0,0,0,0.06)" : "transparent",
                }}>
                <span
                  style={{
                    fontSize: 15,
                    lineHeight: 1,
                    marginBottom: 3,
                    opacity: active ? 1 : 0.4,
                    color: active ? HOME_THEME.accent : HOME_THEME.textPrimary,
                    position: "relative",
                  }}>
                  {tab.icon}
                </span>
                <span
                  style={{
                    fontSize: 9,
                    fontWeight: active ? 600 : 400,
                    position: "relative",
                    color: active ? HOME_THEME.accent : HOME_THEME.textTertiary,
                    letterSpacing: 0.2,
                    fontFamily: FONT_TEXT,
                  }}>
                  {tab.label}
                </span>
              </motion.button>
            );
          })}
        </div>
      </div>
    </motion.nav>
  );
}

function HomeArtboard({ shot, onOpen }) {
  const pageMotion =
    shot.id === "preview"
      ? { y: HOME_PREVIEW_MOTION.y, scale: HOME_PREVIEW_MOTION.scale }
      : { y: shot.scrollY ?? 0, scale: shot.zoom ?? 1 };

  return (
    <div
      style={{
        width: ARTBOARD_WIDTH,
        height: ARTBOARD_HEIGHT,
        display: "flex",
        flexDirection: "column",
        background: HOME_THEME.surface0,
        color: HOME_THEME.textPrimary,
        fontFamily: FONT_TEXT,
        position: "relative",
        overflow: "hidden",
      }}>
      <div
        style={{
          position: "absolute",
          inset: 0,
          background: `
            radial-gradient(circle at 12% 18%, rgba(251,207,232,0.74), transparent 32%),
            radial-gradient(circle at 88% 74%, rgba(253,186,116,0.42), transparent 28%),
            ${HOME_THEME.surface0}
          `,
        }}
      />
      <div
        style={{
          maxWidth: ARTBOARD_WIDTH,
          margin: "0 auto",
          flex: 1,
          minHeight: 0,
          width: "100%",
          display: "flex",
          flexDirection: "column",
          paddingTop: "env(safe-area-inset-top, 0px)",
          paddingBottom: "calc(env(safe-area-inset-bottom, 0px) + 104px)",
          paddingLeft: 20,
          paddingRight: 20,
          position: "relative",
          zIndex: 1,
          overflow: "hidden",
        }}>
        <header
          style={{
            display: "flex",
            alignItems: "center",
            justifyContent: "space-between",
            height: 72,
            flexShrink: 0,
          }}>
          <div
            style={{
              fontSize: 34,
              fontWeight: 700,
              letterSpacing: -0.5,
              color: HOME_THEME.textPrimary,
              fontFamily: FONT_DISPLAY,
            }}>
            Home
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <HeaderButton onClick={() => onOpen("theme-sheet")}>
              <MoonStar className="h-4 w-4" />
            </HeaderButton>
            <HeaderButton onClick={() => onOpen("system-hub")}>
              <Settings2 className="h-4 w-4" />
            </HeaderButton>
          </div>
        </header>

        <motion.div
          animate={pageMotion}
          transition={
            shot.id === "preview"
              ? { duration: 8, ease: [0.22, 1, 0.36, 1], times: [0, 0.18, 0.38, 0.58, 0.82, 1] }
              : { duration: 0.58, ease: [0.22, 1, 0.36, 1] }
          }
          style={{
            minHeight: 2140,
            transformOrigin: "50% 0%",
          }}>
          <HomeView
            settings={{ themeId: "petal-breeze", colorMode: "light" }}
            onTabChange={(trainerId) => onOpen(trainerId === "interval" ? "intervals-handoff" : "system-hub")}
            historyData={HOME_HISTORY}
            progress={HOME_PROGRESS}
            onRecalibrate={() => onOpen("feed-detail")}
          />
        </motion.div>
      </div>

      <EmbeddedTabBar />
    </div>
  );
}

function HomeSurfaceFrame({ shot, onOpen }) {
  return (
    <LangContext.Provider value={{ lang: "mixed", setLang: () => {} }}>
      <ThemeContext.Provider value={{ dark: false, toggle: () => {}, tokens: HOME_THEME }}>
        <HomeArtboard shot={shot} onOpen={onOpen} />
      </ThemeContext.Provider>
    </LangContext.Provider>
  );
}

function HomeShowcaseStage({ pageX = 0, children }) {
  return (
    <motion.div
      animate={{ x: pageX }}
      transition={{ duration: 0.52, ease: [0.22, 1, 0.36, 1] }}
      className="relative z-10 flex h-[calc(100%-132px)] w-full max-w-[1540px] min-h-0 items-stretch overflow-hidden rounded-[48px] md:h-[calc(100%-142px)]">
      <div
        className="pointer-events-none absolute inset-[-12%] blur-3xl"
        style={{
          background:
            "radial-gradient(circle at 14% 18%, rgba(167,196,255,0.36), transparent 22%), radial-gradient(circle at 84% 18%, rgba(255,224,188,0.28), transparent 18%), radial-gradient(circle at 50% 100%, rgba(171,186,255,0.20), transparent 22%)",
        }}
      />
      <div
        className="absolute inset-0 overflow-hidden rounded-[48px]"
        style={{
          border: "1px solid rgba(209,219,241,0.78)",
          background:
            "linear-gradient(180deg, rgba(248,251,255,0.82) 0%, rgba(237,242,251,0.72) 100%)",
          boxShadow:
            "0 28px 90px rgba(96,112,154,0.10), inset 0 1px 0 rgba(255,255,255,0.96), inset 0 -14px 30px rgba(170,186,220,0.08)",
          backdropFilter: "blur(16px)",
          WebkitBackdropFilter: "blur(16px)",
        }}>
        <div
          className="pointer-events-none absolute inset-0 opacity-[0.24]"
          style={{
            backgroundImage:
              "linear-gradient(rgba(155,173,214,0.18) 1px, transparent 1px), linear-gradient(90deg, rgba(155,173,214,0.18) 1px, transparent 1px)",
            backgroundSize: "48px 48px",
            maskImage: "linear-gradient(180deg, rgba(255,255,255,0.9), rgba(255,255,255,0.25))",
            WebkitMaskImage: "linear-gradient(180deg, rgba(255,255,255,0.9), rgba(255,255,255,0.25))",
          }}
        />

        <motion.div
          className="pointer-events-none absolute inset-y-[10%] left-[-12%] w-[28%] rounded-full blur-2xl"
          animate={{ x: ["0%", "180%", "0%"], opacity: [0.12, 0.22, 0.12] }}
          transition={{ duration: 12, repeat: Infinity, ease: "easeInOut" }}
          style={{
            background: "linear-gradient(90deg, transparent, rgba(255,255,255,0.82), transparent)",
          }}
        />

        <motion.div
          className="pointer-events-none absolute inset-y-[24%] left-[-18%] w-[36%] rounded-full blur-3xl"
          animate={{ x: ["0%", "155%", "0%"], opacity: [0.08, 0.16, 0.08] }}
          transition={{ duration: 15, repeat: Infinity, ease: "easeInOut", delay: 1.2 }}
          style={{
            background: "linear-gradient(90deg, transparent, rgba(176,204,255,0.64), transparent)",
          }}
        />

        <motion.div
          className="pointer-events-none absolute inset-y-[4%] right-[-20%] w-[32%] rounded-full blur-3xl"
          animate={{ x: ["0%", "-155%", "0%"], opacity: [0.06, 0.13, 0.06] }}
          transition={{ duration: 16, repeat: Infinity, ease: "easeInOut", delay: 0.8 }}
          style={{
            background: "linear-gradient(90deg, transparent, rgba(255,228,196,0.66), transparent)",
          }}
        />

        <div
          className="pointer-events-none absolute inset-x-[3.5%] top-[4%] h-[1px]"
          style={{
            background:
              "linear-gradient(90deg, transparent, rgba(168,184,226,0.56), rgba(255,255,255,0.94), rgba(168,184,226,0.56), transparent)",
          }}
        />
      </div>
      <div
        className="pointer-events-none absolute inset-0"
        style={{
          background:
            "radial-gradient(circle at 9% 24%, rgba(196,214,255,0.34), transparent 24%), radial-gradient(circle at 91% 16%, rgba(255,228,196,0.28), transparent 18%), linear-gradient(180deg, rgba(255,255,255,0.24), transparent 20%, transparent 84%, rgba(182,196,232,0.10))",
        }}
      />
      <div className="pointer-events-none absolute inset-y-0 left-0 w-[16%] bg-[linear-gradient(90deg,rgba(236,242,252,0.92),transparent)]" />
      <div className="pointer-events-none absolute inset-y-0 right-0 w-[16%] bg-[linear-gradient(270deg,rgba(236,242,252,0.92),transparent)]" />
      <div className="pointer-events-none absolute inset-x-0 bottom-0 h-[18%] bg-[linear-gradient(180deg,transparent,rgba(228,235,248,0.44))]" />
      <div className="relative flex h-full w-full items-start justify-center">{children}</div>
    </motion.div>
  );
}

export function HomeLaunchSurface({ scene, stepIndex }) {
  const shot = getHomeShot(stepIndex);
  const [activeDestination, setActiveDestination] = useState(null);

  useEffect(() => {
    setActiveDestination(shot.autoDestination ?? null);
  }, [shot.id, shot.autoDestination]);

  const destination = activeDestination ? HOME_DESTINATIONS[activeDestination] : null;
  const frameScale = shot.id === "preview" ? 0.95 : 1;

  return (
    <StageFrame scene={scene} step={scene.steps[Math.min(stepIndex, scene.steps.length - 1)]} minimal>
      <div className="relative flex h-full min-h-0 items-center justify-center overflow-hidden px-1 py-1 md:px-3 md:py-3">
        <HomeShowcaseStage pageX={shot.pageX ?? 0}>
          <div className="flex h-full w-full items-start justify-center px-8 py-8">
            <motion.div
              animate={{ scale: ARTBOARD_SCALE * frameScale }}
              transition={{ duration: 0.58, ease: [0.22, 1, 0.36, 1] }}
              style={{
                transformOrigin: "50% 0%",
                width: ARTBOARD_WIDTH,
                height: ARTBOARD_HEIGHT,
                flexShrink: 0,
              }}>
              <HomeSurfaceFrame shot={shot} onOpen={setActiveDestination} />
            </motion.div>
          </div>

          <AnimatePresence>
            {destination ? (
              <DestinationSheet
                destination={destination}
                onClose={() => setActiveDestination(null)}
                onOpen={setActiveDestination}
                passive={Boolean(shot.autoDestination && activeDestination === shot.autoDestination)}
              />
            ) : null}
          </AnimatePresence>
        </HomeShowcaseStage>

        <AnimatePresence mode="wait">
          <FilmCaption key={shot.id} prefix="Home Filmstrip" shot={shot} />
        </AnimatePresence>
      </div>
    </StageFrame>
  );
}
</file>

