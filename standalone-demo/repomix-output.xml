                在指板上找到音程关系。
              </TextAnimate>
            </>
          ) : null}
        </motion.div>

        <motion.div
          initial={{ opacity: 0, scale: 1.08, filter: "blur(20px)" }}
          animate={{
            opacity: isHandoffShot ? 0.72 : 0,
            scale: isHandoffShot ? 0.98 : 1.06,
            filter: isHandoffShot ? "blur(0px)" : "blur(20px)",
          }}
          transition={{ duration: 0.8, ease: [0.22, 1, 0.36, 1] }}
          className="pointer-events-none absolute inset-[8%] overflow-hidden rounded-[40px] border"
          style={{
            borderColor: theme.border,
            background: `linear-gradient(180deg, ${theme.surface2}, rgba(244,247,255,0.86))`,
