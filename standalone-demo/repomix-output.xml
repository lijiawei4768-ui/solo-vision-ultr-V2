export function IntervalsSurface({ scene, stepIndex }) {
  const shot = getIntervalShot(stepIndex);
  const [activeDestination, setActiveDestination] = useState(null);
  useEffect(() => {
    setActiveDestination(shot.autoDestination ?? null);
  }, [shot.id, shot.autoDestination]);

  const destination = activeDestination ? INTERVAL_DESTINATIONS[activeDestination] : null;
  const pageMotion = useMemo(
    () =>
      shot.id === "preview"
        ? INTERVAL_PREVIEW_MOTION
        : {
            y: shot.scrollY ?? 0,
            scale: shot.zoom ?? 1,
          },
    [shot],
  );

  return (
    <StageFrame scene={scene} step={scene.steps[Math.min(stepIndex, scene.steps.length - 1)]} minimal>
      <div className="relative flex h-full min-h-0 items-center justify-center overflow-hidden px-1 py-1 md:px-3 md:py-3">
        <PageFilmCanvas pageX={shot.pageX ?? 0}>
          <motion.div
            animate={pageMotion}
            transition={
              shot.id === "preview"
                ? { duration: 8, ease: [0.22, 1, 0.36, 1], times: [0, 0.18, 0.38, 0.58, 0.82, 1] }
                : { duration: 0.58, ease: [0.22, 1, 0.36, 1] }
            }
            className="relative origin-top px-5 pb-44 pt-6 md:px-8"
            style={{ height: 2450 }}>
            <div className="mx-auto grid max-w-[1240px] gap-5">
              <FocalDimLayer opacity={intervalSectionWeight("modes", shot)}>
                <UtilitySection onOpen={setActiveDestination} />
              </FocalDimLayer>

              <FocalDimLayer opacity={intervalSectionWeight("prompt", shot)} scale={shot.focal === "prompt" ? 1.012 : 1}>
                <PromptSection onOpen={setActiveDestination} />
              </FocalDimLayer>

              <FocalDimLayer opacity={intervalSectionWeight("fretboard", shot)} scale={shot.focal === "fretboard" ? 1.012 : 1}>
                <FretboardSection onOpen={setActiveDestination} />
              </FocalDimLayer>

              <FocalDimLayer opacity={intervalSectionWeight("runtime", shot)}>
                <RuntimeSection onOpen={setActiveDestination} />
              </FocalDimLayer>

              <FocalDimLayer opacity={intervalSectionWeight("controls", shot)}>
                <ControlsSection onOpen={setActiveDestination} />
              </FocalDimLayer>

              <FocalDimLayer opacity={intervalSectionWeight("depth", shot)}>
                <DepthSection onOpen={setActiveDestination} />
              </FocalDimLayer>
            </div>
          </motion.div>

          <AnimatePresence>
            {destination ? (
              <DestinationSheet
                destination={destination}
                onClose={() => setActiveDestination(null)}
                onOpen={setActiveDestination}
                passive={Boolean(shot.autoDestination && activeDestination === shot.autoDestination)}
              />
            ) : null}
          </AnimatePresence>
        </PageFilmCanvas>

        <AnimatePresence mode="wait">
          <FilmCaption key={shot.id} prefix="Intervals Filmstrip" shot={shot} />
        </AnimatePresence>
      </div>
    </StageFrame>
  );
}
</file>

