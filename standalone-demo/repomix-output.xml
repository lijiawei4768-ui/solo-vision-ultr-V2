          <div className="text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.46)]">{column.label}</div>
          <div className="mt-4 text-[1.7rem] tracking-[-0.05em] text-[rgba(248,244,236,0.96)]">{column.value}</div>
        </motion.div>
      ))}
    </div>
  );
}

function Hero({ headline, subline, stats }) {
  return (
    <div className="flex h-full flex-col justify-between">
      <div className="space-y-4">
        <div className="max-w-xl text-[3.6rem] font-semibold leading-[0.94] tracking-[-0.06em] text-[rgba(249,245,235,0.98)]">
          {headline}
        </div>
        <div className="max-w-md text-[1.08rem] leading-7 text-[rgba(208,217,229,0.76)]">{subline}</div>
      </div>
      <div className="grid gap-3 md:grid-cols-3">
        {stats.map((item) => (
          <div
            key={item}
            className="rounded-[24px] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] px-4 py-6 text-[1rem] tracking-[-0.03em] text-[rgba(244,238,228,0.9)]">
            {item}
          </div>
        ))}
      </div>
    </div>
  );
}

function Constellation({ nodes }) {
  return (
    <div className="relative flex h-full items-center justify-center overflow-hidden">
      {nodes.map((node, index) => {
        const angle = (index / nodes.length) * Math.PI * 2;
        const radius = index % 2 === 0 ? 190 : 130;
        const x = Math.cos(angle) * radius;
        const y = Math.sin(angle) * (radius * 0.62);
        return (
          <motion.div
            key={node}
            initial={{ opacity: 0, scale: 0.86 }}
            animate={{ opacity: 1, scale: 1, x, y }}
            transition={{ delay: index * 0.06, duration: 0.36 }}
            className="absolute rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] px-4 py-2 text-sm text-[rgba(221,228,236,0.84)]">
            {node}
          </motion.div>
        );
      })}
      <div className="h-3 w-3 rounded-full bg-[rgba(232,219,190,0.88)] shadow-[0_0_24px_rgba(232,219,190,0.42)]" />
    </div>
  );
}

function Foundation({ blocks }) {
  return (
    <div className="flex h-full flex-col justify-end gap-3">
      <div className="grid gap-3 md:grid-cols-4">
        {blocks.map((block, index) => (
          <motion.div
            key={block}
            initial={{ opacity: 0, y: 24 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: index * 0.07, duration: 0.34 }}
            className="rounded-[24px] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] px-4 py-6 text-center text-sm uppercase tracking-[0.18em] text-[rgba(242,236,227,0.86)]">
            {block}
          </motion.div>
        ))}
      </div>
      <div className="h-[180px] rounded-[32px] border border-[rgba(226,214,186,0.1)] bg-[linear-gradient(180deg,rgba(226,214,186,0.08),rgba(255,255,255,0.02))]" />
    </div>
  );
}

function Scatter({ nodes }) {
  return (
    <div className="relative flex h-full items-center justify-center overflow-hidden">
      {nodes.map((node, index) => {
        const x = (index % 2 === 0 ? -1 : 1) * (70 + index * 44);
        const y = (index - 2) * 36;
        return (
          <motion.div
            key={node}
            initial={{ opacity: 0, scale: 0.6 }}
            animate={{ opacity: 1, scale: 1, x, y }}
            transition={{ delay: index * 0.06, duration: 0.34 }}
            className="absolute flex h-16 w-16 items-center justify-center rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.04)] text-[rgba(245,239,228,0.92)]">
            {node}
          </motion.div>
        );
      })}
    </div>
  );
}

function Fretboard({ lanes }) {
  return (
    <div className="flex h-full flex-col justify-center gap-3">
      {lanes.map((lane, index) => (
        <motion.div
          key={lane}
          initial={{ opacity: 0, x: 14 }}
          animate={{ opacity: 1, x: 0 }}
          transition={{ delay: index * 0.06, duration: 0.3 }}
          className="relative h-20 rounded-[22px] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)]">
          <div className="absolute inset-x-5 top-1/2 h-px -translate-y-1/2 bg-[rgba(255,255,255,0.16)]" />
          <div className="absolute left-5 top-4 text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.46)]">
            {lane}
          </div>
          <div className="absolute inset-y-3 left-[18%] w-px bg-[rgba(255,255,255,0.1)]" />
          <div className="absolute inset-y-3 left-[40%] w-px bg-[rgba(255,255,255,0.1)]" />
          <div className="absolute inset-y-3 left-[65%] w-px bg-[rgba(255,255,255,0.1)]" />
        </motion.div>
      ))}
    </div>
  );
}

function FretboardMap({ points }) {
  return (
    <div className="relative h-full overflow-hidden rounded-[28px] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.02)]">
      <div className="absolute inset-8 grid grid-cols-6 gap-x-0 gap-y-0">
        {Array.from({ length: 36 }).map((_, index) => (
          <div key={index} className="border-r border-t border-[rgba(255,255,255,0.05)]" />
        ))}
      </div>
      {points.map((point, index) => {
        const positions = [
          ["12%", "22%"],
          ["48%", "38%"],
          ["72%", "56%"],
          ["34%", "74%"],
        ];
        const [left, top] = positions[index] ?? ["50%", "50%"];
        return (
          <motion.div
            key={point}
            initial={{ opacity: 0, scale: 0.72 }}
            animate={{ opacity: 1, scale: 1 }}
            transition={{ delay: index * 0.08, duration: 0.34 }}
            className="absolute"
            style={{ left, top }}>
            <div className="h-3 w-3 rounded-full bg-[rgba(232,219,190,0.9)] shadow-[0_0_18px_rgba(232,219,190,0.38)]" />
            <div className="mt-3 rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(8,12,18,0.74)] px-3 py-1.5 text-xs text-[rgba(221,228,236,0.82)]">
              {point}
            </div>
          </motion.div>
        );
      })}
    </div>
  );
}

function Heatmap({ rows }) {
  return (
    <div className="grid h-full gap-3">
      {rows.map((row, rowIndex) => (
        <div key={row} className="space-y-2">
          <div className="text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.44)]">{row}</div>
          <div className="grid grid-cols-6 gap-2">
            {Array.from({ length: 6 }).map((_, index) => {
              const strength = ((index + 1) * (rowIndex + 2) * 9) % 100;
              return (
                <motion.div
                  key={`${row}-${index}`}
                  initial={{ opacity: 0.2 }}
                  animate={{ opacity: 1 }}
                  transition={{ delay: (rowIndex * 6 + index) * 0.02, duration: 0.24 }}
                  className="h-16 rounded-[18px] border border-[rgba(255,255,255,0.08)]"
                  style={{
                    background: `linear-gradient(180deg, rgba(226,214,186,${Math.max(0.08, strength / 180)}), rgba(132,161,205,${Math.max(0.04, strength / 220)}))`,
                  }}
                />
              );
            })}
          </div>
        </div>
      ))}
    </div>
  );
}

function Live({ prompt, status, events }) {
  return (
    <div className="grid h-full gap-4 xl:grid-cols-[minmax(0,1.15fr)_220px]">
      <div className="rounded-[30px] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] p-5">
        <div className="text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.44)]">Live Session</div>
        <div className="mt-4 text-[1.45rem] tracking-[-0.04em] text-[rgba(248,244,236,0.96)]">{prompt}</div>
        <div className="mt-6 flex flex-col gap-3">
          {events.map((event) => (
            <div
              key={event}
              className="rounded-[22px] border border-[rgba(255,255,255,0.08)] bg-[rgba(10,14,20,0.52)] px-4 py-3 text-sm text-[rgba(223,229,236,0.82)]">
              {event}
            </div>
          ))}
        </div>
      </div>
      <div className="rounded-[30px] border border-[rgba(226,214,186,0.12)] bg-[rgba(226,214,186,0.04)] p-5">
        <div className="text-[10px] uppercase tracking-[0.28em] text-[rgba(194,203,216,0.44)]">Status</div>
        <div className="mt-4 text-[1.5rem] tracking-[-0.04em] text-[rgba(248,244,236,0.96)]">{status}</div>
        <Separator className="my-5 bg-[rgba(255,255,255,0.08)]" />
        <div className="space-y-2">
          <Pill>Prompt active</Pill>
          <Pill>Audio listening</Pill>
          <Pill>Feedback ready</Pill>
        </div>
      </div>
    </div>
  );
}

export function SceneVisual({ scene, step }) {
  const visual = step.visual ?? {};

  return (
    <VisualFrame eyebrow={scene.englishLabel} title={step.heading} detail={scene.categoryLabel}>
      {visual.type === "hero" ? <Hero {...visual} /> : null}
      {visual.type === "constellation" ? <Constellation {...visual} /> : null}
      {visual.type === "stack" ? <Stack {...visual} /> : null}
      {visual.type === "contrast" ? <Contrast {...visual} /> : null}
      {visual.type === "rings" ? <Rings {...visual} /> : null}
      {visual.type === "pipeline" ? <Pipeline {...visual} /> : null}
      {visual.type === "matrix" ? <Matrix {...visual} /> : null}
      {visual.type === "ecosystem" ? <Ecosystem {...visual} /> : null}
      {visual.type === "quadrants" ? <Quadrants {...visual} /> : null}
      {visual.type === "timeline" ? <Timeline {...visual} /> : null}
      {visual.type === "ladder" ? <Ladder {...visual} /> : null}
      {visual.type === "foundation" ? <Foundation {...visual} /> : null}
      {visual.type === "scatter" ? <Scatter {...visual} /> : null}
      {visual.type === "fretboard" ? <Fretboard {...visual} /> : null}
      {visual.type === "fretboard-map" ? <FretboardMap {...visual} /> : null}
      {visual.type === "heatmap" ? <Heatmap {...visual} /> : null}
      {visual.type === "resolver" ? <Resolver {...visual} /> : null}
      {visual.type === "spectrum" ? <Spectrum {...visual} /> : null}
      {visual.type === "live" ? <Live {...visual} /> : null}
    </VisualFrame>
  );
}
