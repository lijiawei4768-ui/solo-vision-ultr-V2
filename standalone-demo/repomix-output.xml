          </div>
          <div className="absolute left-8 right-8 top-32 h-[290px] rounded-[30px] border px-8 py-8" style={{ borderColor: theme.border, background: `linear-gradient(180deg, ${theme.surface2}, ${theme.surface0})` }}>
            <div className="grid h-full gap-6 md:grid-cols-[1.2fr_0.8fr]">
              <div>
                <div className="inline-flex rounded-full border px-3 py-1.5 text-[10px] uppercase tracking-[0.22em]" style={{ borderColor: theme.accentBorder, background: theme.accentSub, color: theme.accent }}>
