function intervalSectionWeight(section, shot) {
  if (!shot.focal) return 1;
  if (shot.focal === "prompt") {
    if (section === "prompt") return 1;
    if (section === "modes") return 0.72;
    return 0.46;
  }
  if (shot.focal === "modes") return section === "modes" ? 1 : section === "prompt" ? 0.68 : 0.46;
  if (shot.focal === "fretboard") return section === "fretboard" ? 1 : section === "runtime" ? 0.62 : 0.46;
  if (shot.focal === "runtime") return section === "runtime" ? 1 : 0.46;
  if (shot.focal === "controls") return section === "controls" ? 1 : 0.46;
  if (shot.focal === "depth") return section === "depth" ? 1 : 0.46;
  return 1;
}

