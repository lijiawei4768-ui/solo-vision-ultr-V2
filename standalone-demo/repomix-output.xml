    <StageFrame scene={scene} step={step}>
      <div className="grid h-full gap-4 xl:grid-cols-[0.92fr_1.08fr]">
        <Panel title="Old Reading To Remove" label="Home Misread">
          <div className="grid gap-3">
            {[
              ["Songs / Courses", "内容不是主入口。"],
              ["Feature Boxes", "不是靠功能拼图解释产品。"],
              ["Scale Boxes", "不再把训练理解成模板形状。"],
            ].map(([title, body]) => (
              <EchoCard key={title} title={title} body={body} />
            ))}
          </div>
        </Panel>

        <div className="grid gap-4">
          <HeaderRail
            left={
              <>
                <Sparkles className="h-4 w-4" />
                <span>SVU Product Lens</span>
              </>
            }
            right={
              <>
                <Chip active>Current Product</Chip>
                <Chip>Upgraded Reading</Chip>
              </>
            }
          />

          <Panel title="不是内容型吉他 app" label="Cognition Shift" className="flex-1">
            <div className="grid h-full gap-5">
              <HeroBlock
                title="它首先在训练关系、系统、语义与导航。"
