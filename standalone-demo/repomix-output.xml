import { motion } from "motion/react";

import { StageFrame } from "@/components/presentation/chrome/StageFrame";
import { useThemeBridge } from "@/components/presentation/proof/ThemeBridge";
import { TextAnimate } from "@/components/ui/text-animate";

export function BrandOpeningSurface({ scene, stepIndex }) {
  const theme = useThemeBridge();
  const isAnchorShot = stepIndex >= 1;
  const isHandoffShot = stepIndex >= 2;

  return (
    <StageFrame scene={scene} step={scene.steps[Math.min(stepIndex, scene.steps.length - 1)]} minimal>
      <div className="relative flex h-full items-center justify-center overflow-hidden rounded-[44px]">
        <motion.div
          className="absolute left-1/2 top-1/2 h-[58vh] w-[58vw] -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
          style={{
            background: `radial-gradient(circle, ${theme.bg.blobA}, ${theme.bg.blobB} 42%, transparent 72%)`,
          }}
          animate={{ opacity: [0.42, 0.74, 0.42], scale: [1.16, 1, 1.08] }}
          transition={{ duration: 6.6, repeat: Infinity, ease: "easeInOut" }}
